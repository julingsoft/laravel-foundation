{
    "name": "juling/laravel-foundation",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.4",
        "alibabacloud/aliyun-log-php-sdk": "^0.6.8",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "zircote/swagger-php": "^6.1"
    },
    "autoload": {
        "psr-4": {
            "Juling\\Foundation\\": "foundation/src/"
        },
        "files": [
            "foundation/src/Support/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Juling\\Foundation\\FoundationServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
